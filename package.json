{
  "name": "almaflow",
  "version": "0.1.0",
  "private": true,
  "description": "Alumni Weekend Accommodation & Operations Management System",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @almaflow/database prisma generate",
    "db:push": "pnpm --filter @almaflow/database prisma db push",
    "db:migrate": "pnpm --filter @almaflow/database prisma migrate dev",
    "db:seed": "pnpm --filter @almaflow/database prisma db seed",
    "db:studio": "pnpm --filter @almaflow/database prisma studio"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "turbo": "^2.8.3"
  }
}
